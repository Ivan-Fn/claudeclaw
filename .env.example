# Master Agent Configuration
# Copy to .env and fill in your values

# ── Telegram ────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Comma-separated list of allowed Telegram chat IDs
# Get yours by messaging @userinfobot on Telegram
# REQUIRED: Bot will refuse to start if empty (security)
ALLOWED_CHAT_IDS=

# ── Slack (Optional) ─────────────────────────────────────────────────
# 1. Create a Slack app at https://api.slack.com/apps
# 2. Enable Socket Mode (Settings > Socket Mode) -> generates xapp-... token
# 3. Add Bot Token Scopes: chat:write, files:read, files:write, im:history, im:read, im:write
# 4. Install app to workspace -> generates xoxb-... token
# 5. Subscribe to Events: message.im (for DMs)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Comma-separated list of allowed Slack channel/DM IDs (e.g., D1234567,C7654321)
# Leave empty to allow all channels where the bot is invited
SLACK_ALLOWED_CHANNEL_IDS=

# Comma-separated list of allowed Slack user IDs (e.g., U1234567)
# Leave empty to allow all users in allowed channels
SLACK_ALLOWED_USER_IDS=

# ── Claude Auth (optional) ────────────────────────────────────────────
# Uses your existing Claude Code auth (claude login) by default.
# Set ANTHROPIC_API_KEY to use pay-per-token billing instead.
ANTHROPIC_API_KEY=

# Override which Claude account is used (optional)
# CLAUDE_CODE_OAUTH_TOKEN=

# Optional: Additional system prompt appended to Claude Code's default
CLAUDE_SYSTEM_PROMPT_APPEND=

# ── Voice (Optional) ───────────────────────────────────────────────────
# Groq API key for Whisper STT (voice transcription)
# Get from https://console.groq.com/keys
GROQ_API_KEY=

# ElevenLabs API key + voice ID for TTS (voice responses)
# Get from https://elevenlabs.io/
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── n8n Integration (Optional) ────────────────────────────────────────
# Self-hosted n8n instance URL (no trailing slash)
N8N_BASE_URL=http://localhost:5678
# Optional: API key for n8n webhook authentication
# Configure Header Auth in n8n with header name X-N8N-API-KEY
N8N_API_KEY=

# ── Gemini API (Optional) ────────────────────────────────────────────────
# Google Gemini API key for image generation and multimodal skills
# Get from https://aistudio.google.com/app/apikey
# Passed to agent subprocess as GOOGLE_API_KEY for the google-genai SDK
GEMINI_API_KEY=

# ── Bot Identity ───────────────────────────────────────────────────────
# Name used for DB file, PID file, and log messages (default: master-agent)
# BOT_NAME=master-agent

# Display name shown in start messages and status (default: Master Agent)
# BOT_DISPLAY_NAME=Master Agent

# Custom /start message (overrides the default "BOT_DISPLAY_NAME online..." greeting)
# Use this for custom welcome messages, localized greetings, etc.
# BOT_START_MESSAGE=Welcome! Send me a message to get started.

# ── Agent Behavior ──────────────────────────────────────────────────────
# Agent query timeout in milliseconds (default: 300000 = 5 minutes)
AGENT_TIMEOUT_MS=300000

# Max auto-continue retries on timeout (default: 3)
# MAX_TIMEOUT_RETRIES=3

# Override the working directory for Claude Code sessions
# Defaults to the bot's own directory. Set this when the agent
# should work in a different project (e.g., a separate codebase).
# AGENT_CWD=/path/to/project

# Daily cost limit in USD (default: 0 = unlimited)
# When reached, the agent refuses new queries until midnight.
# AGENT_DAILY_COST_LIMIT_USD=10.00

# Send restart notification to all allowed chats (default: true)
# NOTIFY_ON_RESTART=true

# Claude settings sources: comma-separated (default: user,project)
# Set to 'project' to only load project-level settings (isolates from user MCP servers, etc.)
# SETTINGS_SOURCES=user,project

# Extra env vars to forward to Claude agent subprocess (comma-separated)
# Use this to pass credentials the agent needs (e.g., Cloudflare, AWS)
# AGENT_FORWARD_ENV=CLOUDFLARE_API_TOKEN,CLOUDFLARE_ACCOUNT_ID

# MCP servers to pass directly to the Claude Agent SDK (JSON string)
# This is the reliable way to make MCP tools available -- settings.json mcpServers
# are not always loaded by the SDK subprocess.
# Format: {"name": {"command": "...", "args": [...], "env": {...}}}
# AGENT_MCP_SERVERS={"google-workspace": {"command": "uvx", "args": ["workspace-mcp", "--single-user", "--tools", "gmail", "calendar", "--tool-tier", "core"]}}
