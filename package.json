{
  "name": "claudeclaw",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "prebuild": "bash scripts/generate-version.sh",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "setup": "tsx scripts/setup.ts",
    "setup:skills": "bash scripts/setup-global-skills.sh",
    "skills": "tsx scripts/skills.ts",
    "status": "tsx scripts/status.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.59",
    "@hono/node-server": "^1.19.11",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.14.1",
    "better-sqlite3": "^12.6.2",
    "cron-parser": "^5.5.0",
    "grammy": "^1.40.1",
    "hono": "^4.12.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
