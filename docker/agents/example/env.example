# Agent environment variables
# ────────────────────────────────────────────────────────────────────────
# Fill in directly for plain text, or replace values with op:// references
# for 1Password, or encrypt this file with SOPS. DO NOT commit with real values.

# Required
TELEGRAM_BOT_TOKEN=
CLAUDE_CODE_OAUTH_TOKEN=
ALLOWED_CHAT_IDS=

# GitHub (required for creating PRs)
GH_TOKEN=

# Git identity (used inside the container)
GIT_AUTHOR_NAME=Your Name
GIT_AUTHOR_EMAIL=you@example.com

# Agent behavior
AGENT_CWD=/repos
AGENT_TIMEOUT_MS=600000
MAX_TIMEOUT_RETRIES=5
AGENT_DAILY_COST_LIMIT_USD=10.00

# Bot identity
BOT_NAME=my-agent
BOT_DISPLAY_NAME=My Agent
