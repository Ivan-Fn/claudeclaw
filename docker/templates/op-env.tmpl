# 1Password secret references for {{AGENT_NAME}}
# Values are resolved at startup via `op run` -- never written to disk.

# Required
TELEGRAM_BOT_TOKEN=op://{{OP_VAULT}}/{{AGENT_NAME}}-telegram/token
CLAUDE_CODE_OAUTH_TOKEN=op://{{OP_VAULT}}/claude-oauth/oauth-token
ALLOWED_CHAT_IDS=op://{{OP_VAULT}}/{{AGENT_NAME}}-config/allowed-chat-ids

# GitHub (required for creating PRs)
GH_TOKEN=op://{{OP_VAULT}}/{{AGENT_NAME}}-github-pat/token

# Git identity
GIT_AUTHOR_NAME={{AGENT_DISPLAY_NAME}}
GIT_AUTHOR_EMAIL={{AGENT_NAME}}@bot.local

# Agent behavior
AGENT_CWD=/repos
AGENT_TIMEOUT_MS=600000
MAX_TIMEOUT_RETRIES=5
AGENT_DAILY_COST_LIMIT_USD=10.00

# Bot identity
BOT_NAME={{AGENT_NAME}}
BOT_DISPLAY_NAME={{AGENT_DISPLAY_NAME}}
